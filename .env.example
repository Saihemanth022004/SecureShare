# Flask
FLASK_ENV=development

# Firebase Admin (pick one method)
# 1) Path to service account JSON
FIREBASE_SERVICE_ACCOUNT_PATH=C:/path/to/serviceAccountKey.json

# or 2) Raw service account JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# or 3) Individual service account fields
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY_ID=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_CLIENT_ID=
# FIREBASE_CLIENT_CERT_URL=

# Firebase Storage bucket (required for file/QR storage)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase Web config (public values used by login page)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=your-project-id
FIREBASE_WEB_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=

# Threat intelligence API key (optional – improves scan accuracy)
THREAT_API_KEY=
